# eviStream Frontend Environment Variables
# Copy this file to .env.local and set your backend URL:
#   cp .env.local.example .env.local
#
# For local development:
#   NEXT_PUBLIC_API_URL=http://localhost:8001
#
# For EC2 deployment (replace with your Elastic IP or domain):
#   NEXT_PUBLIC_API_URL=http://YOUR_EC2_PUBLIC_IP

NEXT_PUBLIC_API_URL=http://YOUR_EC2_PUBLIC_IP
